server {
    listen 80;
    server_name mydomain.com;

    # ACME challenge for Certbot:
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Everything else → HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name mydomain.com;

    ssl_certificate     /etc/letsencrypt/live/mydomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mydomain.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Your public‑facing site content
 return 404;
}

# ───────────────────────────────────────────────────────────────────────────────
# 2) Internal‑only proxy on server_private_ip:8443
# ───────────────────────────────────────────────────────────────────────────────
server {
    # Bind only to LAN IP on port 8443
    listen server_private_ip:8443 ssl http2;
    server_name mydomain.com;  # can also use an internal-only name

    ssl_certificate     /etc/letsencrypt/live/mydomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mydomain.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    location /emby/ {

        allow private ip to access emby;
        allow private ip to access emby;
        allow private ip to access emby;
        deny all;

        proxy_pass         http://server_private_ip:8096/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";
    }

  location /homer/ {


       allow private ip to access homer;
